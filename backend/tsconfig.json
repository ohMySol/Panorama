{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "rootDir": "..",
    "outDir": "./dist",
    "removeComments": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@risk-terminal/shared": ["../packages/shared/src/index.ts"]
    }
  }
}